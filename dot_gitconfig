# vim: set filetype=gitconfig
[user]
    email = sieppertcalum@gmail.com
    name = Calum Sieppert
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPZMtlnLN51ZmIkMxsg1bGDsoazyOlDemuhq1Jb0LuEO
[credential]
    credentialStore = gpg
    helper = /usr/bin/git-credential-manager
[rerere]
    enabled = true
    autoUpdate = true
[pull]
    rebase = false
[fetch]
    prune = true
[alias]
    st = status
    sts = status -s
    ci = commit
    cia = commit -a
    cim = commit -m
    ciam = commit -am
    co = checkout
    cob = checkout -b
    dt = difftool
    dtd = difftool -d
    # Difftastic aliases, so `git dlog` is `git log` with difftastic and so on.
    dlog = -c diff.external=difft log --ext-diff
    dshow = -c diff.external=difft show --ext-diff
    ddiff = -c diff.external=difft diff
[diff]
    tool = nvim_difftool
    guitool = nvim_difftool
    colorMoved = default
    submodule = log
[difftool "ediff"]
    cmd = ~/scripts/ediff.sh $LOCAL $REMOTE $MERGED
[difftool "nvim_difftool"]
    # --cmd here for setting flatten_wait is important so the variable is set before the flatten module is loaded.
    # "+" is important so the diff command runs after the new tab page is opened
    cmd = ~/scripts/nvim-cmd.sh --cmd \"let g:flatten_wait=1\" +\"packadd nvim.difftool | DiffTool $LOCAL $REMOTE\"
[merge]
    tool = nvimdiff
    conflictstyle = diff3
[mergetool "ediff"]
    cmd = ~/scripts/ediff.sh $LOCAL $REMOTE $MERGED $BASE
    trustExitCode = true
[core]
    autocrlf = input
    pager = delta
    fsmonitor = true
{{ if eq .chezmoi.os "windows" }}
    # From bitwarden ssh agent docs
    sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
    # Windows optimizations from https://github.com/Vigorpush/git-speedup
    preloadIndex = true
    fscache = true
    ignoreStat = false
    # Requires developer mode on Windows
    symlinks = true
{{ end }}
[interactive]
    diffFilter = delta --color-only
[add.interactive]
    useBuiltin = false # required for git 2.37.0 + git-delta
[delta]
    syntax-theme = Nord
    navigate = true    # use n and N to move between diff sections
    line-numbers = true
[github]
    user = rynoV
[init]
    defaultBranch = master
[credential "https://dev.azure.com"]
    useHttpPath = true
[submodule]
    recurse = true
[safe]
    directory = /opt/flutter
[status]
    submoduleSummary = 1
    compareBranches = @{upstream} @{push}
[push]
    useForceIfIncludes = true
    default = current
[commit]
    gpgsign = true
[gpg "ssh"]
    allowedSignersFile = ~/.ssh/allowed_signers
{{ if eq .chezmoi.os "windows" }}
    # From bitwarden ssh agent docs
    program = C:/Windows/System32/OpenSSH/ssh-keygen.exe
{{ end }}
[gpg]
    format = ssh
[hook "ensure-signed"] # Requires git 2.54 or later
    event = pre-push
    command = ~/scripts/ensure-signed.sh
{{ if eq .chezmoi.os "windows" }}
[gc]
    # Windows optimizations from https://github.com/Vigorpush/git-speedup
    auto = 256
{{ end }}
